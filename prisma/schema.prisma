generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model pengguna {
  id            String        @id @default(uuid())
  nama          String
  email         String        @unique
  password      String
  peran         Peran
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  daftarAbsensi Absensi[]
  logAbsenGuru  AbsensiGuru[]
  daftarMurid   Murid[]
}

model Murid {
  id               String    @id @default(uuid())
  tanggalMasuk     DateTime  @default(now())
  namaLengkap      String
  namaPanggilan    String
  kelas            String
  sekolahAsal      String
  namaOrangTuaWali String
  pekerjaanAyah    String
  pekerjaanIbu     String
  alamatDomisili   String
  noHpOrangTua     String
  hari             String
  pembayaran       String
  mapel            String
  catatanAnak      String?
  createdAt        DateTime  @default(now())
  guruId           String
  jam              String
  updatedAt        DateTime  @updatedAt
  riwayatAbsensi   Absensi[]
  guru             Pengguna  @relation(fields: [guruId], references: [id])

  @@index([guruId])
}

model Absensi {
  id      String        @id @default(uuid())
  tanggal DateTime      @default(now())
  muridId String
  guruId  String
  status  StatusAbsensi
  guru    Pengguna      @relation(fields: [guruId], references: [id])
  murid   Murid         @relation(fields: [muridId], references: [id], onDelete: Cascade)

  @@index([tanggal])
  @@index([guruId])
  @@index([muridId])
}

model AbsensiGuru {
  id         String   @id @default(uuid())
  waktuMasuk DateTime @default(now())
  guruId     String
  guru       Pengguna @relation(fields: [guruId], references: [id])
}

enum Peran {
  ADMIN
  GURU
}

enum StatusAbsensi {
  HADIR
  IZIN
  SAKIT
  ALPHA
}
