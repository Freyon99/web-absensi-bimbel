generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// 2. DI BAWAH INI BARU MASUKKAN MODEL ANDA YANG KEMARIN
model Pengguna {
  id              String            @id @default(uuid())
  nama            String
  email           String            @unique
  password        String
  peran           Peran
  createdAt       DateTime          @default(now())

  daftarMurid     Murid[]
  daftarAbsensi   Absensi[]
  logAbsenGuru    AbsensiGuru[]
}

model Murid {
  id               String   @id @default(uuid())
  tanggalMasuk     DateTime @default(now())
  namaLengkap      String
  namaPanggilan    String
  kelas            String
  sekolahAsal      String
  namaOrangTuaWali String
  pekerjaanAyah    String
  pekerjaanIbu     String
  alamatDomisili   String
  noHpOrangTua     String
  hari             String
  jam              String
  pembayaran       String
  mapel            String
  catatanAnak      String?  @db.Text
  createdAt        DateTime @default(now())

  guruId           String
  guru             Pengguna   @relation(fields: [guruId], references: [id])
  riwayatAbsensi   Absensi[]
}

model Absensi {
  id          String    @id @default(uuid())
  tanggal     DateTime  @default(now())
  status      String    

  muridId     String
  murid       Murid     @relation(fields: [muridId], references: [id], onDelete: Cascade)

  guruId      String
  guru        Pengguna  @relation(fields: [guruId], references: [id])
}

model AbsensiGuru {
  id          String    @id @default(uuid())
  waktuMasuk  DateTime  @default(now())

  guruId      String
  guru        Pengguna  @relation(fields: [guruId], references: [id])
}

enum Peran {
  ADMIN
  GURU
}