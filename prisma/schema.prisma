generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Pengguna {
  id            String        @id @default(uuid())
  nama          String
  email         String        @unique
  password      String
  peran         Peran
  noHp          String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  daftarAbsensi Absensi[]
  logAbsenGuru  AbsensiGuru[]
  daftarMurid   Murid[]
}

model Murid {
  id               String    @id @default(uuid())
  tanggalMasuk     DateTime  @default(now())
  namaLengkap      String
  namaPanggilan    String
  kelas            String
  sekolahAsal      String
  namaOrangTuaWali String
  pekerjaanAyah    String
  pekerjaanIbu     String
  alamatDomisili   String
  noHpOrangTua     String
  hari             String
  pembayaran       String
  mapel            String
  catatanAnak      String?
  createdAt        DateTime  @default(now())
  guruId           String?
  jam              String
  updatedAt        DateTime  @updatedAt
  riwayatAbsensi   Absensi[]
  guru             Pengguna? @relation(fields: [guruId], references: [id], onDelete: SetNull)

  @@index([guruId])
}

model Absensi {
  id      String        @id @default(uuid())
  tanggal DateTime      @default(now())
  muridId String
  guruId  String?
  status  StatusAbsensi
  guru    Pengguna?     @relation(fields: [guruId], references: [id], onDelete: SetNull)
  murid   Murid         @relation(fields: [muridId], references: [id], onDelete: Cascade) // Murid tetap cascade agar jika murid dihapus, absensinya ikut terhapus

  @@index([tanggal])
  @@index([guruId])
  @@index([muridId])
}

model AbsensiGuru {
  id          String    @id @default(uuid())
  waktuMasuk  DateTime  @default(now())
  waktuPulang DateTime? // Tambahkan kolom opsional ini
  guruId      String
  guru        Pengguna  @relation(fields: [guruId], references: [id], onDelete: Cascade)
}

enum Peran {
  ADMIN
  GURU
}

enum StatusAbsensi {
  HADIR
  IZIN
  SAKIT
  ALPHA
}